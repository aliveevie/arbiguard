ARBITRUM_ONE_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
DEPLOYER_PRIVATE_KEY=0x...
AGENT_PRIVATE_KEY=0x...
CHAINLINK_VRF_SUBSCRIPTION_ID=
PORT=3000

# OpenAI (server-side only — used for chat routing and natural replies)
# Place this file in the repo root (same folder as package.json). The server loads it automatically.
# You can also use .env.local (overrides .env) or set OPENAI_API_KEY in Docker / Render.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
