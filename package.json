{
  "name": "arbiguard",
  "version": "1.0.0",
  "description": "AI-Agent Skill for Real-Time DeFi Threat Detection and Autonomous Protective Response on Arbitrum",
  "author": "IBX Lab",
  "license": "MIT",
  "type": "module",
  "main": "dist/skill/index.js",
  "scripts": {
    "build": "pnpm run build:ui && pnpm run build:server",
    "build:ui": "pnpm --dir arbiguard-ui install && pnpm --dir arbiguard-ui build",
    "build:server": "tsc",
    "start": "node dist/server/index.js",
    "dev": "tsx watch server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "skill:register": "tsx skill/actions/registerAgent.ts",
    "demo": "tsx demo/agent.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "express": "^4.21.0",
    "openai": "^6.33.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
